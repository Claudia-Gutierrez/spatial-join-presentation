boroughs = st_read("geodata/GM_lad.gpkg", quiet = TRUE)
stops = st_read("geodata/Metrolink_Stops_Functional.json", quiet = TRUE)
boroughs = st_transform(boroughs, 27700)
stops = st_transform(stops, 27700)
inputs = ggplot() +
geom_sf(data = boroughs, fill = "grey95", colour = "white", linewidth = 0.2) +
geom_sf(data = stops, colour = "#6C2EB9", size = 2) +
labs(title = "Tram stops (points) and neighbourhoods (polygons)") +
theme_void() +
theme(
plot.title = element_text(size = 20, face = "bold", hjust = 0.5)
)
